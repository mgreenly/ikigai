#!/usr/bin/env bash
# bin/secrets — seed/rotate dropbox's secrets in the shared app-config blob.
#
# Workstation-side control-plane action (no ssh, no box). NON-DESTRUCTIVE
# read-modify-write of ONLY this app's key in /metaspot/<ACCOUNT>/app-config
# (a single SecureString shared across every app on the box). Every other
# app's key in the blob is preserved untouched.
#
# dropbox has exactly three secrets — the single-box Dropbox app credential
# (PLAN.md §9, decision Account model): DROPBOX_APP_KEY, DROPBOX_APP_SECRET,
# DROPBOX_REFRESH_TOKEN (app `ikigai-onebox`, App-folder scoped). The binary reads
# them via getenv at its composition root. They MUST be seeded BEFORE first start —
# metaspot-launch hard-fails if .["dropbox"] is missing from app-config.
#
# Values come from ~/.secrets/<NAME> (same source as the local .envrc); any can be
# overridden by an env var of the same name. The values are NEVER read aloud,
# printed, or logged — only masked in the summary below. Non-secret config (resource
# id, auth server, db/mirror/generation paths, app-folder root, longpoll timeout,
# max-entry-retries) is NOT stored here — the wrapper at /opt/dropbox/bin/run derives
# it from METASPOT_DOMAIN/PORT.
#
# Requires a live SSO session (`aws sso login --profile ai`) — the user runs
# that interactively; this script does not.
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO"
. etc/manifest.env
. etc/deploy.env

PARAM="/metaspot/${ACCOUNT}/app-config"
AWS_PROFILE_NAME="${AWS_PROFILE:-${ACCOUNT}}"
AWS_REGION_NAME="${AWS_REGION:-us-east-2}"
SECRETS_DIR="${SECRETS_DIR:-$HOME/.secrets}"

aws_() { aws --profile "$AWS_PROFILE_NAME" --region "$AWS_REGION_NAME" "$@"; }

resolve() {
  local name="$1" val
  if [ -n "${!name:-}" ]; then
    val="${!name}"
  elif [ -r "$SECRETS_DIR/$name" ]; then
    val="$(cat "$SECRETS_DIR/$name")"
  else
    echo "!! $name not set and $SECRETS_DIR/$name not readable" >&2
    exit 1
  fi
  printf '%s' "$val" | tr -d '[:space:]'
}

APP_KEY="$(resolve DROPBOX_APP_KEY)"
APP_SECRET="$(resolve DROPBOX_APP_SECRET)"
REFRESH_TOKEN="$(resolve DROPBOX_REFRESH_TOKEN)"

[ -n "$APP_KEY" ]       || { echo "!! DROPBOX_APP_KEY is empty" >&2; exit 1; }
[ -n "$APP_SECRET" ]    || { echo "!! DROPBOX_APP_SECRET is empty" >&2; exit 1; }
[ -n "$REFRESH_TOKEN" ] || { echo "!! DROPBOX_REFRESH_TOKEN is empty" >&2; exit 1; }

EXISTING="$(aws_ ssm get-parameter --name "$PARAM" --with-decryption \
  --query Parameter.Value --output text 2>/dev/null || true)"
if BASE="$(printf '%s' "$EXISTING" | jq -e . 2>/dev/null)"; then :; else BASE='{}'; fi

NEW="$(printf '%s' "$BASE" | jq \
  --arg n "$APP" --arg key "$APP_KEY" --arg secret "$APP_SECRET" --arg refresh "$REFRESH_TOKEN" \
  '.[$n] = {DROPBOX_APP_KEY:$key, DROPBOX_APP_SECRET:$secret, DROPBOX_REFRESH_TOKEN:$refresh}')"

mask() { local s="$1"; [ "${#s}" -le 8 ] && { echo '****'; return; }; \
         printf '%s…%s\n' "${s:0:4}" "${s: -4}"; }
SIBLINGS="$(printf '%s' "$BASE" | jq -r --arg n "$APP" \
  'keys - [$n] | join(", ") | if . == "" then "(none)" else . end')"

echo
echo "  SECRETS — write key .${APP} into ${PARAM}"
echo "    profile/region          : ${AWS_PROFILE_NAME} / ${AWS_REGION_NAME}"
echo "    DROPBOX_APP_KEY         : $(mask "$APP_KEY")"
echo "    DROPBOX_APP_SECRET      : $(mask "$APP_SECRET")"
echo "    DROPBOX_REFRESH_TOKEN   : $(mask "$REFRESH_TOKEN")"
echo "    sibling keys preserved  : $SIBLINGS"
echo
printf '  Type "yes" to write: '
read -r ANS
[ "$ANS" = "yes" ] || { echo ">> aborted (nothing written)."; exit 1; }

TMP="$(mktemp)"; chmod 600 "$TMP"
trap 'rm -f "$TMP"' EXIT
printf '%s' "$NEW" > "$TMP"
aws_ ssm put-parameter --name "$PARAM" \
  --type SecureString --overwrite --value "file://$TMP" >/dev/null

echo ">> .${APP} written to ${PARAM}. Apply with: bin/ship (then opsctl stage/deploy) or systemctl restart ${APP}."
