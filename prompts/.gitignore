# Build artifacts
/build/
# Stray bare binary from a module-root `go build` (never committed)
/prompts

# SQLite databases (runtime; default path is ./tmp/prompts.db)
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Runtime on-disk state: the SQLite file, per-session sandbox folders, and
# per-run stream-json logs all live under data/ and are never committed.
/data/
/tmp/

# Build loop ephemeral brief (created by gather, deleted by verify; never committed)
/project/loops/brief.md

# Local environment
.env
.env.local

# Editor / OS
.DS_Store
*.swp
*.swo
.idea/
.vscode/
