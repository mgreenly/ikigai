#!/usr/bin/env bash
# bin/teardown — the inverse of bin/setup: remove agent's footprint from the box.
#
# agent is a path-routed service that owns NOTHING global — so teardown is the
# mirror of setup and no more: stop+disable the unit, remove /opt/prompts (incl.
# data/ = the DB AND the sandbox/run folders), drop the nginx location fragment,
# and reload nginx.
#
#   bin/teardown                  remove unit + nginx fragment + app code;
#                                 PRESERVE /opt/prompts/data (DB + sandboxes + runs).
#   bin/teardown --purge-data     also rm -rf /opt/prompts and userdel agent.
#
# Never touches shared box state: it does NOT uninstall python3 (a shared box
# resource agent did not exclusively own), does NOT touch the apex server block,
# the TLS cert, or the /_authn hook (all the dashboard's), and does NOT remove the
# conf.d/locations/ dir (shared with sibling services). Safe to run repeatedly /
# on a half-torn box.
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO"
. etc/manifest.env
. etc/deploy.env

HOST="${HOST:-${ACCOUNT}.${APEX_SUFFIX:-ikigenba.com}}"
SSH_KEY="${SSH_KEY/#\~/$HOME}"

PURGE_DATA=0
for arg in "$@"; do
  case "$arg" in
    --purge-data) PURGE_DATA=1 ;;
    *) echo "usage: bin/teardown [--purge-data]" >&2; exit 2 ;;
  esac
done

echo ">> teardown: ${SSH_USER}@${HOST}  app=${APP}  mount=${MOUNT}  (service fragment only)"
echo "   data: $([ "$PURGE_DATA" = 1 ] && echo 'PURGE (rm -rf /opt/'"${APP}"' + userdel — DB, sandboxes, runs)' || echo 'preserve /opt/'"${APP}"'/data')"

ssh -i "$SSH_KEY" "${SSH_USER}@${HOST}" \
  "sudo APP='$APP' PURGE_DATA='$PURGE_DATA' bash -s" <<'REMOTE'
set -euo pipefail
: "${APP:?}"
PURGE_DATA="${PURGE_DATA:-0}"

echo ">> stop + remove systemd unit"
systemctl stop    "${APP}.service" 2>/dev/null || true
systemctl disable "${APP}.service" 2>/dev/null || true
rm -f "/etc/systemd/system/${APP}.service"
systemctl daemon-reload

echo ">> remove nginx location fragment"
rm -f "/etc/nginx/conf.d/locations/${APP}.conf"
if nginx -t 2>/dev/null; then
  systemctl reload nginx
else
  echo "!! nginx -t failed after removing ${APP}.conf — NOT reloading (inspect manually)" >&2
fi

echo ">> app files"
if [ "$PURGE_DATA" = 1 ]; then
  rm -rf "/opt/${APP}"
  userdel "${APP}" 2>/dev/null || true
  echo "   purged /opt/${APP} (DB + sandboxes + runs) and user ${APP}"
else
  rm -rf "/opt/${APP}/bin" "/opt/${APP}/etc"
  echo "   removed code; preserved /opt/${APP}/data (and user ${APP})"
fi

echo ">> NOTE: python3 left installed (shared box resource — not agent-owned)."
echo ">> teardown complete."
REMOTE

echo ">> done."
