#!/usr/bin/env bash
# bin/start — run agent locally on its loopback port, writing its PID to build/agent.pid.
#
# Local-run only. The systemd-on-the-box lifecycle is owned by opsctl (deploy + the start/stop passthroughs).
# agent binds 127.0.0.1 by default; nginx is its only real ingress.
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO"
. etc/manifest.env

BIN="build/${APP}.bin"
PIDFILE="build/${APP}.pid"

# Soft preflight: agent boots fine without python3 — only the agent's bash/python
# toolset needs it. Warn, never fail.
command -v python3 >/dev/null || echo "warning: python3 not found; agent bash/python tooling will fail" >&2

if [[ ! -x "$BIN" ]]; then
  bin/build
fi

if [[ -f "$PIDFILE" ]] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
  echo "agent already running (pid $(cat "$PIDFILE"))" >&2
  exit 1
fi

PROMPTS_PORT="${PROMPTS_PORT:-${PORT}}" "./$BIN" --port "${PROMPTS_PORT:-${PORT}}" &
echo $! > "$PIDFILE"
echo "agent started (pid $(cat "$PIDFILE")) on 127.0.0.1:${PROMPTS_PORT:-${PORT}}"
