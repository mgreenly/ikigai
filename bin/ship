#!/usr/bin/env bash
# bin/ship — the ONE shared SHIP wrapper for the whole suite (laptop side).
# Renamed from bin/deploy; replaces the per-service cloned */bin/deploy.
#
#   bin/ship <app>
#
# It is deliberately thin: it owns the OFF-BOX BUILD HALF only, and its ONLY box
# write is the scp of the versioned release bundle into the box's /tmp. It does
# NOT stage, deploy, migrate, or swap anything — no install logic runs over ssh
# from the laptop. The box owns every state change. After the scp, ship PRINTS
# the two box commands the operator runs next (`opsctl stage …` then
# `opsctl deploy …`) and STOPS.
#
# The version core is the committed file <app>/VERSION (vX.Y.Z) — git tags are
# NO LONGER the version mechanism. ship always builds CURRENT main (HEAD);
# whatever version is committed in <app>/VERSION on HEAD is what ships, plus
# SemVer build metadata for the built commit (<version>+<sha>). There is no
# version argument: bump the file with bin/bump first, then ship builds that
# committed state.
#
# What it does:
#   1. Source <app>/etc/deploy.env (ACCOUNT, SSH_USER, SSH_KEY, APEX_SUFFIX;
#      HOST defaults to ${ACCOUNT}.${APEX_SUFFIX}).
#   2. Add a throwaway detached `git worktree` of HEAD and read the version core
#      FROM THE WORKTREE'S <app>/VERSION (the actual build source), then append
#      +<sha> build metadata for the built commit.
#   3. EARLY EXISTENCE CHECK: ssh `test -e /opt/<app>/libexec/<app>-v<ver>+<sha>` — if
#      the binary already exists on the box, refuse unless --force. This runs AFTER
#      the cheap worktree add + VERSION read but BEFORE the expensive compile, so
#      a forgotten bin/bump fails before the build.
#   4. Build CURRENT main (HEAD) inside the worktree's <app>/ dir (PLAN §4 dec 4)
#      so the build is reproducible, excludes any uncommitted working-tree edits,
#      and never disturbs the operator's tree. Build flags honor §2:
#      CGO_ENABLED=0 GOOS=linux GOARCH=amd64 GOWORK=off -trimpath -buildvcs=false,
#      ldflags stamping appkit.version to the full v<core>+<sha>. The committed
#      `replace appkit/eventplane/agentkit => ../...` directives resolve against
#      the worktree's sibling lib trees (no network).
#   5. Bundle the binary as <app> with nginx.conf, manifest.env, and optional
#      share/.
#   6. scp the bundle to the box /tmp/<app>-v<ver>+<sha>.tar.gz, then STOP —
#      printing the two box commands (`sudo opsctl stage …`, then
#      `sudo opsctl deploy …`).
#
# --dry-run (or DRY_RUN=1) does the FULL build (producing the bundle) but PRINTS
# the existence check / scp commands instead of running them, so the build half is
# fully exercisable off-box while the box half stays gated.
#
# Honors §2: the box never compiles; -buildvcs=false is mandatory (the module is a
# subdir of a bare mono-repo .git — Go's auto VCS stamp would abort); GOWORK=off so
# the prod build is deterministic without the dev workspace; the in-repo lib source
# trees come along in the worktree for the replace directives. Never reads or prints
# secrets / the SSH key contents.
set -euo pipefail

usage() {
  cat <<'USAGE'
bin/ship — build the current main of a suite service off-box and ship the release bundle to the box /tmp.

Usage:
  bin/ship <app>

Arguments:
  <app>        service to ship (ledger, crm, dashboard, ...). Its
               <app>/etc/deploy.env supplies ACCOUNT / SSH_USER / SSH_KEY / HOST.

There is no version argument. ship builds CURRENT main (HEAD); the release
version core is read from the committed file <app>/VERSION (vX.Y.Z) and shipped
as v<X.Y.Z>+<sha>. Bump the file first with `bin/bump <app> <field>`.

ship's ONLY box write is the scp of the release bundle to /tmp. It does NOT stage,
deploy, or migrate — the box owns every state change. After the scp it prints the
two box commands the operator runs next (opsctl stage, then opsctl deploy) and
stops.

Flags:
  -h, --help   show this help.
  --force      ship even if /opt/<app>/libexec/<app>-v<ver>+<sha> already exists on the box
               (otherwise ship refuses, so a forgotten bin/bump fails early).
  --dry-run    do the full off-box build (produce the bundle) but PRINT the
               existence-check / scp commands instead of running them.
               Equivalent to DRY_RUN=1.

Environment:
  DRY_RUN=1    same as --dry-run.

What it does:
  source <app>/etc/deploy.env
  -> add a throwaway detached `git worktree` of HEAD, read v<X.Y.Z> from its <app>/VERSION
  -> early existence check: ssh test -e /opt/<app>/libexec/<app>-v<X.Y.Z>+<sha> (refuse unless --force)
  -> build CURRENT main (HEAD) in the worktree
     (CGO_ENABLED=0 GOOS=linux GOARCH=amd64 GOWORK=off -trimpath -buildvcs=false,
      ldflags -X appkit.version=v<X.Y.Z>+<sha>)
  -> bundle the built binary, nginx.conf, manifest.env, and optional share/
  -> scp the bundle to the box /tmp/<app>-v<X.Y.Z>+<sha>.tar.gz
  -> STOP, printing the box commands:
       sudo opsctl stage  <app> v<X.Y.Z>+<sha> --artifact /tmp/<app>-v<X.Y.Z>+<sha>.tar.gz
       sudo opsctl deploy <app> v<X.Y.Z>+<sha>

There is NO install logic locally and NO ssh stage/deploy/install run from the
laptop: opsctl on the box owns release dirs, atomic swap, migrate, restart, and
rollback.
USAGE
}

# --- parse args -------------------------------------------------------------
DRY_RUN="${DRY_RUN:-0}"
FORCE=0
APP=""
for arg in "$@"; do
  case "$arg" in
    -h|--help)  usage; exit 0 ;;
    --dry-run)  DRY_RUN=1 ;;
    --force)    FORCE=1 ;;
    -*)         echo "!! unknown flag: $arg" >&2; usage >&2; exit 2 ;;
    *)
      if [ -z "$APP" ]; then APP="$arg"
      else echo "!! too many arguments: $arg" >&2; usage >&2; exit 2
      fi
      ;;
  esac
done

[ -n "$APP" ] || { echo "!! missing <app>" >&2; usage >&2; exit 2; }

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO"

[ -d "$APP" ] || { echo "!! no such service dir: ${APP}/" >&2; exit 1; }
[ -f "${APP}/etc/deploy.env" ] || { echo "!! missing ${APP}/etc/deploy.env" >&2; exit 1; }
[ -f "${APP}/VERSION" ] || { echo "!! missing ${APP}/VERSION (the committed version source of truth) — bump it with bin/bump first" >&2; exit 1; }

# --- routing/auth config (non-secret) --------------------------------------
# shellcheck source=/dev/null
. "${APP}/etc/deploy.env"
HOST="${HOST:-${ACCOUNT}.${APEX_SUFFIX:-ikigenba.com}}"
SSH_KEY="${SSH_KEY/#\~/$HOME}"   # expand a leading ~ ; contents are never read/printed
: "${SSH_USER:?SSH_USER must be set in ${APP}/etc/deploy.env}"

# --- resolve the build commit -> current main (HEAD) -----------------------
# Git tags are NO LONGER the version mechanism. The build source is always the
# current main tip (HEAD): whatever is committed on main is what ships. The
# version itself is read below from the worktree's <app>/VERSION (the actual build
# source), not from any tag.
SHA="$(git rev-parse --short HEAD)"
COMMIT_STAMP="${SHA}"
BRANCH="$(git branch --show-current)"
if [ "$BRANCH" != "main" ]; then
  echo "!! ship must run from the main worktree (currently on '${BRANCH}') — it builds the standing worktree's HEAD, and deploys ship committed main" >&2
  exit 1
fi

echo ">> ${APP}: building current main (HEAD ${SHA})"

# --- throwaway worktree of HEAD --------------------------------------------
WORKTREE="$(mktemp -d "${TMPDIR:-/tmp}/suite-ship-${APP}.XXXXXX")"
ARTIFACT_DIR="$(mktemp -d "${TMPDIR:-/tmp}/suite-artifact-${APP}.XXXXXX")"

cleanup() {
  # Remove the throwaway worktree on exit (success OR failure), then its dir.
  git worktree remove --force "$WORKTREE" >/dev/null 2>&1 || rm -rf "$WORKTREE"
  git worktree prune >/dev/null 2>&1 || true
}
trap cleanup EXIT

echo ">> git worktree add --detach ${WORKTREE} HEAD"
# mktemp created the dir; --detach onto an existing empty dir needs it gone first.
rm -rf "$WORKTREE"
# Detached checkout of HEAD — this materializes exactly what is committed on main,
# EXCLUDING any uncommitted edits in the operator's working tree. That guarantee
# (artifact == committed main) is the whole point of the file-on-main model.
git worktree add --detach "$WORKTREE" HEAD >/dev/null

# --- read the version FROM THE WORKTREE's <app>/VERSION ---------------------
# Read the v-prefixed version core from the actual build source (the worktree),
# strip whitespace/newline, validate it is vX.Y.Z, then append +<sha> build
# metadata from the built commit. That full SemVer is the release name handed to
# opsctl / used in the box release dir and stamped into the binary — matching how
# the binary self-reports.
VER="$(tr -d '[:space:]' < "$WORKTREE/$APP/VERSION")"
if [[ ! "$VER" =~ ^v[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  echo "!! ${APP}/VERSION (in the build worktree) is not a v-prefixed SemVer (got: '${VER}')" >&2
  exit 1
fi

# The build source is the worktree — a detached checkout of HEAD. Re-derive the
# dirty flag FROM THE WORKTREE (the actual build source), so the stamp tells the
# truth about exactly what was compiled. Clean by construction for a HEAD checkout
# with no uncommitted changes in the worktree (the normal case) -> empty suffix;
# the generic check still surfaces "-dirty" if a build is ever driven from a dirty
# source tree.
if [ -n "$(git -C "$WORKTREE" status --porcelain)" ]; then
  COMMIT_STAMP="${SHA}-dirty"
fi
FULL_VERSION="${VER}+${COMMIT_STAMP}"
LIBEXEC_DIR="${ARTIFACT_DIR}/libexec"
mkdir -p "$LIBEXEC_DIR"
ARTIFACT="${LIBEXEC_DIR}/${APP}-${FULL_VERSION}"
BUNDLE_ROOT="${ARTIFACT_DIR}/bundle-root"
BUNDLE="${ARTIFACT_DIR}/${APP}-${FULL_VERSION}.tar.gz"

echo ">> ${APP}: release ${FULL_VERSION}"

# --- early existence check (cheap, BEFORE the expensive compile) ------------
# Refuse if /opt/<app>/libexec/<app>-v<ver> already exists on the box, unless --force.
# This catches a forgotten `bin/bump` (re-shipping an already-present version)
# before paying for the build. It runs after the cheap worktree add + VERSION
# read (which is where <ver> comes from) but before the compile. ec2-user can
# `test -e` /opt/<app>/libexec at 0755; fall back to `sudo test -e` if not.
REMOTE_BINARY="/opt/${APP}/libexec/${APP}-${FULL_VERSION}"
EXISTS_CMD=(ssh -i "$SSH_KEY" "${SSH_USER}@${HOST}"
  "test -e ${REMOTE_BINARY} || sudo test -e ${REMOTE_BINARY}")

if [ "$DRY_RUN" = "1" ]; then
  echo ">> DRY RUN — not checking the box. The existence check would run:"
  echo "   ${EXISTS_CMD[*]}"
elif [ "$FORCE" = "1" ]; then
  echo ">> --force: skipping the box existence check for ${REMOTE_BINARY}"
else
  echo ">> checking the box: ${REMOTE_BINARY} must not already exist"
  if "${EXISTS_CMD[@]}" 2>/dev/null; then
    echo "!! ${REMOTE_BINARY} already exists on ${HOST} — did you forget 'bin/bump ${APP}'?" >&2
    echo "!! re-ship this exact version with --force (the box stage's collision guard still applies)." >&2
    exit 1
  fi
fi

# --- build inside the worktree's <app>/ dir --------------------------------
# Running inside <app>/ makes ./cmd/<app> and the `replace … => ../<lib>`
# directives resolve against the worktree's sibling lib trees — no network, no
# go.work (GOWORK=off). The artifact lands OUTSIDE the worktree so it survives
# the worktree removal.
LDFLAGS="-s -w -X appkit.version=${FULL_VERSION} -X appkit.commit="
echo ">> build ${APP} -> ${ARTIFACT}"
(
  cd "${WORKTREE}/${APP}"
  CGO_ENABLED=0 GOOS=linux GOARCH=amd64 GOWORK=off \
    go build -trimpath -buildvcs=false \
      -ldflags "${LDFLAGS}" \
      -o "${ARTIFACT}" "./cmd/${APP}"
)
[ -x "$ARTIFACT" ] || { echo "!! build did not produce ${ARTIFACT}" >&2; exit 1; }
echo ">> built $(basename "$ARTIFACT") ($(du -h "$ARTIFACT" | cut -f1))"

# --- build the release bundle ---------------------------------------------
for required in nginx.conf manifest.env; do
  [ -f "${WORKTREE}/${APP}/etc/${required}" ] || {
    echo "!! missing ${APP}/etc/${required} in the build worktree" >&2
    exit 1
  }
done

mkdir -p "$BUNDLE_ROOT"
cp "$ARTIFACT" "${BUNDLE_ROOT}/${APP}"
chmod 0755 "${BUNDLE_ROOT}/${APP}"
cp "${WORKTREE}/${APP}/etc/nginx.conf" "${BUNDLE_ROOT}/nginx.conf"
cp "${WORKTREE}/${APP}/etc/manifest.env" "${BUNDLE_ROOT}/manifest.env"

TAR_ENTRIES=("$APP" "nginx.conf" "manifest.env")
if [ -d "${WORKTREE}/${APP}/share" ]; then
  cp -a "${WORKTREE}/${APP}/share" "${BUNDLE_ROOT}/share"
  TAR_ENTRIES+=("share")
fi

tar -C "$BUNDLE_ROOT" -czf "$BUNDLE" "${TAR_ENTRIES[@]}"
[ -f "$BUNDLE" ] || { echo "!! bundle did not produce ${BUNDLE}" >&2; exit 1; }
echo ">> bundled $(basename "$BUNDLE") ($(du -h "$BUNDLE" | cut -f1))"

# --- ship the bundle to the box /tmp (the ONLY box write) ------------------
# ship's box footprint stops here: scp into /tmp, then print the box commands.
# No stage/deploy/install runs over ssh — the box owns every state change.
REMOTE_ARTIFACT="/tmp/${APP}-${FULL_VERSION}.tar.gz"
SCP_CMD=(scp -i "$SSH_KEY" "$BUNDLE" "${SSH_USER}@${HOST}:${REMOTE_ARTIFACT}")

# The two box commands the operator runs next (printed after the scp, or in
# dry-run). These exactly match opsctl's stage/deploy synopsis.
STAGE_CMD="sudo opsctl stage  ${APP} ${FULL_VERSION} --artifact ${REMOTE_ARTIFACT}"
DEPLOY_CMD="sudo opsctl deploy ${APP} ${FULL_VERSION}"

if [ "$DRY_RUN" = "1" ]; then
  echo ">> DRY RUN — not shipping. The box write would be:"
  echo "   ${SCP_CMD[*]}"
  echo ">> then, ON THE BOX (${HOST}), the operator would run:"
  echo "   ${STAGE_CMD}"
  echo "   ${DEPLOY_CMD}"
  echo ">> dry-run complete. Artifact: ${BUNDLE}"
  exit 0
fi

echo ">> scp ${APP} ${FULL_VERSION} -> ${HOST}:${REMOTE_ARTIFACT}"
"${SCP_CMD[@]}"

echo ">> SHIPPED -> ${HOST}:${REMOTE_ARTIFACT}  (${APP} ${FULL_VERSION}, branch ${BRANCH})"
echo ">>"
echo ">> Next, ON THE BOX (${HOST}), run:"
echo "     ${STAGE_CMD}"
echo "     ${DEPLOY_CMD}"
echo ">>"
echo ">> ship's job is done — it does NOT stage or deploy. The box owns every state change."
