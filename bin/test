#!/usr/bin/env bash
# bin/test — the suite's test entry point. Runs the repo-wide guards and tests in
# one place so CI (and `make`-less local checks) have a single command:
#
#   bin/test
#
# Order, fail-fast on the first failing stage:
#   1. bin/check-migrations — the migration guard (naming / uniqueness /
#      immutability). Cheapest and earliest: a colliding or edited migration
#      should fail the run before anything is built or any other test runs.
#      See docs/adr-migration-timestamps.md.
#   2. the repo-root shell tests (bin/*.test.sh).
#   3. go test across every workspace module (go.work).
#
# See docs/plan-migration-timestamps.md.
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO"

echo "==> check-migrations"
bin/check-migrations

echo "==> shell tests (bin/*.test.sh)"
for t in bin/*.test.sh; do
  [ -e "$t" ] || continue
  echo "--- $t"
  "$t"
done

echo "==> go test (all workspace modules)"
while IFS= read -r module; do
  echo "--- ${module#$REPO/}"
  (cd "$module" && go test ./...)
done < <(go list -m -f '{{.Dir}}')

echo "==> all tests passed"
