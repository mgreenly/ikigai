#!/usr/bin/env bash
# bin/new-migration — generate a new, correctly-named, immutable schema migration
# for a suite service. This is the SINGLE point at which a migration version number
# comes into existence: agents never hand-pick a number and never type a migration
# filename by hand.
#
#   bin/new-migration <service> <name>
#
# The version is a generated 14-digit UTC timestamp (date -u +%Y%m%d%H%M%S), so two
# agents on two branches generating a migration at different wall-clock seconds get
# different versions and the merge carries both with no collision. Timestamps sort
# strictly after the frozen legacy integer migrations (001_…, 002_…), so the two
# schemes coexist in one sorted run. See docs/adr-migration-timestamps.md.
#
# What it does:
#   1. Validate <service>/internal/db/migrations exists.
#   2. Refuse a <name> that slugifies to the library-coupled shared files
#      (outbox / feed_offset) — those are frozen and owned by the event-plane lib.
#   3. Slugify <name>: lowercase, runs of non-alphanumerics -> single underscore,
#      trim leading/trailing underscores.
#   4. Stamp the version: date -u +%Y%m%d%H%M%S.
#   5. Write <service>/internal/db/migrations/<ts>_<slug>.sql with a templated
#      header. If that exact path already exists, FAIL (never silently collide).
#   6. Print the created path.
#
# A committed migration is IMMUTABLE — never edit or delete it; change schema by
# adding another new migration. bin/check-migrations enforces this in CI.
set -euo pipefail

usage() {
  cat <<'USAGE'
bin/new-migration — generate a new timestamped, immutable schema migration for a service.

Usage:
  bin/new-migration <service> <name>

Arguments:
  <service>    service to add the migration to (crm, ledger, dashboard, ...). Must
               have a <service>/internal/db/migrations directory.
  <name>       descriptive name; slugified into the filename (lowercased, runs of
               non-alphanumerics collapsed to a single underscore, ends trimmed).

The version is a generated 14-digit UTC timestamp (YYYYMMDDHHMMSS) — never
hand-picked. The file is written as <service>/internal/db/migrations/<ts>_<slug>.sql
and its path is printed. A committed migration is immutable: change schema by
adding a new one. See docs/adr-migration-timestamps.md.

Flags:
  -h, --help   show this help.
USAGE
}

# --- parse args -------------------------------------------------------------
SERVICE=""
NAME=""
for arg in "$@"; do
  case "$arg" in
    -h|--help)  usage; exit 0 ;;
    -*)         echo "!! unknown flag: $arg" >&2; usage >&2; exit 2 ;;
    *)
      if [ -z "$SERVICE" ]; then SERVICE="$arg"
      elif [ -z "$NAME" ]; then NAME="$arg"
      else echo "!! too many arguments: $arg" >&2; usage >&2; exit 2
      fi
      ;;
  esac
done

[ -n "$SERVICE" ] || { echo "!! missing <service>" >&2; usage >&2; exit 2; }
[ -n "$NAME" ]    || { echo "!! missing <name>" >&2; usage >&2; exit 2; }

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO"

# --- validate the service migrations dir ------------------------------------
MIG_DIR="${SERVICE}/internal/db/migrations"
if [ ! -d "$MIG_DIR" ]; then
  echo "!! no migrations dir: ${MIG_DIR}" >&2
  echo "!! valid services (have internal/db/migrations):" >&2
  for d in */internal/db/migrations; do
    [ -d "$d" ] && echo "     ${d%%/*}" >&2
  done
  exit 1
fi

# --- slugify <name> ---------------------------------------------------------
# lowercase -> non-alphanumeric runs to single '_' -> trim leading/trailing '_'.
SLUG="$(printf '%s' "$NAME" \
  | tr '[:upper:]' '[:lower:]' \
  | sed -e 's/[^a-z0-9]\{1,\}/_/g' -e 's/^_\{1,\}//' -e 's/_\{1,\}$//')"

[ -n "$SLUG" ] || { echo "!! <name> '${NAME}' slugifies to empty — give it alphanumerics" >&2; exit 2; }

# --- refuse the frozen, library-coupled shared files ------------------------
# outbox (producers) and feed_offset (consumers) are owned by the event-plane
# library convention and keep their frozen legacy integer prefixes. The generator
# refuses to create them.
case "$SLUG" in
  outbox|feed_offset)
    echo "!! refusing to generate '${SLUG}' — the shared outbox/feed_offset migrations are" >&2
    echo "!! library-coupled and frozen; see docs/adr-migration-timestamps.md" >&2
    exit 1
    ;;
esac

# --- stamp the version + build the target path ------------------------------
TS="$(date -u +%Y%m%d%H%M%S)"
TARGET="${MIG_DIR}/${TS}_${SLUG}.sql"

if [ -e "$TARGET" ]; then
  echo "!! ${TARGET} already exists — refusing to collide (try again next second)" >&2
  exit 1
fi

# --- write the templated migration ------------------------------------------
cat >"$TARGET" <<SQL
-- migration: ${TS}_${SLUG}
-- Generated by bin/new-migration. This migration is IMMUTABLE: never edit or
-- delete it once committed — change schema by adding a new migration.
-- See docs/adr-migration-timestamps.md.

-- TODO: write the forward-only schema change below.
SQL

echo "$TARGET"
