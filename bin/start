#!/usr/bin/env bash
#
# start — local-dev orchestrator: build and stand up the whole suite for manual
# testing. This is the dev mirror of the on-box systemd story (each service's own
# bin/start is systemctl control on the box) — here it native-builds every Go
# service, launches each on its loopback port, and brings up the nginx front door
# on :8080 so the full path-routed auth chain is reachable end to end.
#
# Counterpart: bin/stop tears the whole stack back down.
#
# Per-service env/secrets come from each service's own .envrc (sourced in a
# scoped subshell so secrets reach the process env and nothing else). Binaries,
# logs, pidfiles, and SQLite state all live under tmp/ (gitignored).
set -euo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo="$(cd "$here/.." && pwd)"
RUN_DIR="$repo/tmp"
MANIFEST_ROOT="$RUN_DIR/opt"
SERVICES=(dashboard crm ledger notify prompts wiki dropbox cron gmail scripts sites webhooks)
mkdir -p "$RUN_DIR/bin"

# stage_manifest_root — build the local runtime manifest root that matches the
# production /opt shape: <svc>/etc/<version>/manifest.env plus current -> version.
stage_manifest_root() {
	local svc version src dst

	rm -rf "$MANIFEST_ROOT"
	for svc in "${SERVICES[@]}"; do
		src="$repo/$svc/etc/manifest.env"
		[ -f "$src" ] || continue

		version="dev"
		if [ -s "$repo/$svc/VERSION" ]; then
			version="$(tr -d '\r\n' <"$repo/$svc/VERSION")"
			[ -n "$version" ] || version="dev"
		fi

		dst="$MANIFEST_ROOT/$svc/etc/$version"
		mkdir -p "$dst"
		cp "$src" "$dst/manifest.env"
		ln -s "$version" "$MANIFEST_ROOT/$svc/etc/current"
	done
}

# running <name> — true if a tracked, live process exists for <name>.
running() {
	local pf="$RUN_DIR/$1.pid"
	[ -f "$pf" ] && kill -0 "$(cat "$pf")" 2>/dev/null
}

# run_bg <name> <launch-fn> — invoke <launch-fn> in a scoped subshell, detached,
# with stdout+stderr to tmp/<name>.log and the resulting PID in tmp/<name>.pid.
# The launch fn ends in `exec`, so the recorded PID is the server itself (clean
# to signal from bin/stop).
run_bg() {
	local name="$1" fn="$2"
	if running "$name"; then
		echo "  $name already running (pid $(cat "$RUN_DIR/$name.pid")) — skipping"
		return 0
	fi
	("$fn") >"$RUN_DIR/$name.log" 2>&1 &
	echo $! >"$RUN_DIR/$name.pid"
	echo "  started $name (pid $!) -> tmp/$name.log"
}

# build_svc <name> — native build of <name>/cmd/<name> into tmp/bin/<name>. -C
# runs go from the service dir; the root go.work (one level up) resolves the
# shared appkit/eventplane/agentkit libs without a network fetch. -buildvcs=false
# for the same reason the shared bin/ship build half uses it: Go's VCS stamping
# walks up to the bare mono-repo .git and fails (exit 128), and the stamp is not
# needed for dev. (This is the dev mirror; prod ships via bin/ship -> opsctl.)
build_svc() {
	echo "  building $1"
	go build -C "$repo/$1" -buildvcs=false -o "$RUN_DIR/bin/$1" ./cmd/"$1"
}

# --- per-service launchers (each sources its .envrc, then execs its binary) ---
# DB paths are pinned under tmp/ so dev state is isolated and wiped with bin/stop
# --clean. Resource-id / auth-server defaults already point at the :8080 front
# door, so only the port and db path need setting here.

# source_up — the per-service .envrc files start with direnv's `source_up` to
# inherit the repo-root .envrc (GOFLAGS). We source those files in plain bash, not
# direnv, so provide a shim that does the same inherit. Defined in the parent
# shell; the run_bg `(...)` subshells inherit it.
source_up() { source "$repo/.envrc"; }

launch_dashboard() {
	# dashboard/.envrc supplies GOOGLE_* secrets, DASHBOARD_PUBLIC_BASE_URL
	# (http://localhost:8080), then bin/start points manifest readers at the
	# staged runtime root under tmp/opt.
	source "$repo/dashboard/.envrc"
	export DASHBOARD_DB_PATH="$RUN_DIR/dashboard.db"
	export DASHBOARD_MANIFEST_ROOT="$MANIFEST_ROOT"
	export REGISTRY_ROOT="$MANIFEST_ROOT"
	exec "$RUN_DIR/bin/dashboard" serve --port 3000
}

launch_crm() {
	export CRM_DB_PATH="$RUN_DIR/crm.db"
	exec "$RUN_DIR/bin/crm" serve --port 3100
}

launch_ledger() {
	export LEDGER_DB_PATH="$RUN_DIR/ledger.db"
	exec "$RUN_DIR/bin/ledger" serve --port 3101
}

launch_notify() {
	# notify/.envrc supplies NTFY_* secrets and resolves CRM_FEED_URL by name via
	# bin/registry. Re-resolve through the staged runtime root so dev matches the
	# box's etc/current manifest layout.
	source "$repo/notify/.envrc"
	export NOTIFY_DB_PATH="$RUN_DIR/notify.db"
	export REGISTRY_ROOT="$MANIFEST_ROOT"
	export CRM_FEED_URL="$("$repo/bin/registry" feed-url crm)"
	exec "$RUN_DIR/bin/notify" serve --port 3201
}

launch_prompts() {
	source "$repo/prompts/.envrc"
	export PROMPTS_DB_PATH="$RUN_DIR/prompts.db"
	exec "$RUN_DIR/bin/prompts" serve --port 3002
}

launch_wiki() {
	# wiki/.envrc supplies ANTHROPIC_API_KEY (from ~/.secrets) for ingest + ask.
	source "$repo/wiki/.envrc"
	export WIKI_DB_PATH="$RUN_DIR/wiki.db"
	exec "$RUN_DIR/bin/wiki" serve --port 3001
}

launch_dropbox() {
	# dropbox/.envrc supplies DROPBOX_APP_KEY/SECRET/REFRESH_TOKEN (from ~/.secrets).
	# The local mirror lives under tmp/ so it's wiped with bin/stop --clean.
	source "$repo/dropbox/.envrc"
	export DROPBOX_DB_PATH="$RUN_DIR/dropbox.db"
	export DROPBOX_MIRROR_PATH="$RUN_DIR/dropbox-mirror"
	exec "$RUN_DIR/bin/dropbox" serve --port 3200
}

launch_cron() {
	# cron holds no secret and needs no extra config.
	export CRON_DB_PATH="$RUN_DIR/cron.db"
	export CRON_GENERATION_PATH="$RUN_DIR/cron.db.generation"
	exec "$RUN_DIR/bin/cron" serve --port 3005
}

launch_gmail() {
	# gmail/.envrc supplies GMAIL_CLIENT_ID/SECRET/REFRESH_TOKEN (from ~/.secrets).
	source "$repo/gmail/.envrc"
	export GMAIL_DB_PATH="$RUN_DIR/gmail.db"
	exec "$RUN_DIR/bin/gmail" serve --port 3202
}

launch_scripts() {
	# scripts holds no secret; it's a multi-upstream event-plane consumer whose
	# SCRIPTS_<SRC>_FEED_URL values default to the loopback /feed of each peer.
	source "$repo/scripts/.envrc"
	export SCRIPTS_DB_PATH="$RUN_DIR/scripts.db"
	exec "$RUN_DIR/bin/scripts" serve --port 3003
}

launch_sites() {
	# sites is a pure MCP service; SITES_ROOT is the sandbox root for served sites.
	export SITES_DB_PATH="$RUN_DIR/sites.db"
	export SITES_ROOT="$RUN_DIR/sites-root"
	mkdir -p "$SITES_ROOT"
	exec "$RUN_DIR/bin/sites" serve --port 3004
}

launch_webhooks() {
	# webhooks holds no secret; the public /in/ ingress self-guards on per-webhook
	# secrets. DB under tmp/ so it's wiped with bin/stop --clean.
	export WEBHOOKS_DB_PATH="$RUN_DIR/webhooks.db"
	exec "$RUN_DIR/bin/webhooks" serve --port 3006
}

launch_nginx() {
	# nginx/run regenerates the dev /srv/<svc>/ fragments (via bin/registry) and
	# execs nginx with `daemon off`, so the tracked PID is the nginx master.
	export REGISTRY_ROOT="$MANIFEST_ROOT"
	exec "$repo/nginx/run"
}

# wait_port <port> — best-effort readiness probe: true once <port> accepts a
# loopback TCP connection (up to ~5s).
wait_port() {
	local i
	for i in $(seq 1 50); do
		if (exec 3<>"/dev/tcp/127.0.0.1/$1") 2>/dev/null; then
			exec 3>&- 3<&- 2>/dev/null || true
			return 0
		fi
		sleep 0.1
	done
	return 1
}

echo ">> staging runtime manifests"
stage_manifest_root

echo ">> building services"
for svc in "${SERVICES[@]}"; do
	build_svc "$svc"
done

echo ">> starting services"
# Order: dashboard (the AS) first; crm before notify (notify consumes crm's
# /feed); nginx last, once the upstreams it proxies are up.
run_bg dashboard launch_dashboard
run_bg crm launch_crm
run_bg ledger launch_ledger
run_bg dropbox launch_dropbox
run_bg cron launch_cron
run_bg gmail launch_gmail
run_bg prompts launch_prompts
run_bg scripts launch_scripts
run_bg sites launch_sites
run_bg webhooks launch_webhooks
run_bg wiki launch_wiki
run_bg notify launch_notify
run_bg nginx launch_nginx

echo ">> waiting for listeners"
declare -A PORTS=([dashboard]=3000 [crm]=3100 [ledger]=3101 [notify]=3201 [prompts]=3002 [dropbox]=3200 [wiki]=3001 [cron]=3005 [gmail]=3202 [scripts]=3003 [sites]=3004 [webhooks]=3006 [nginx]=8080)
fail=0
for name in dashboard crm ledger notify prompts dropbox cron gmail scripts sites webhooks wiki nginx; do
	port="${PORTS[$name]}"
	if ! running "$name"; then
		echo "  ✗ $name exited — see tmp/$name.log"
		fail=1
		continue
	fi
	if wait_port "$port"; then
		echo "  ✓ $name listening on :$port"
	else
		echo "  ✗ $name not listening on :$port (still building? see tmp/$name.log)"
		fail=1
	fi
done

cat <<EOF

Suite up. Front door: http://localhost:8080  (apex -> dashboard)
  /srv/crm/  /srv/ledger/  /srv/notify/  /srv/prompts/  /srv/dropbox/  /srv/cron/  /srv/gmail/  /srv/scripts/  /srv/sites/  /srv/webhooks/  /srv/wiki/
Loopback:  dashboard :3000  crm :3100  ledger :3101  notify :3201  prompts :3002
           dropbox :3200  wiki :3001  cron :3005  gmail :3202  scripts :3003  sites :3004  webhooks :3006
Logs: tmp/<svc>.log   Stop: bin/stop   (bin/stop --clean also wipes tmp/ state)
EOF

exit "$fail"
