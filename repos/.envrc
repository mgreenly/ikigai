# Inherit the repo-root .envrc (GOFLAGS=-buildvcs=false for the worktree layout).
source_up

# The session engine's default provider is anthropic (REPOS_PROVIDER /
# REPOS_MODEL, design D5); the key is referenced (not read) here — the `cat`
# runs later in your shell, so the value never enters an agent's context.
export ANTHROPIC_API_KEY="$(cat ~/.secrets/ANTHROPIC_API_KEY)"

# Non-secret local-dev config (REPOS_* public config) gets added here when the
# service is built — port 3007, db path, state root — composed the same way
# the sibling services do.
