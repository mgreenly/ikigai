{
  "name": "set model to openai gpt-5.4-pro with low reasoning",
  "steps": [
    {"send_keys": "/clear\\r"},
    {"wait": 0.5},
    {"send_keys": "/model gpt-5.4-pro/low\\r"},
    {"wait": 0.5},
    {"mock_expect": {"responses": [{"content": "Mock response from gpt-5.4-pro."}]}},
    {"send_keys": "Hello\\r"},
    {"wait_idle": 30000},
    {"read_framebuffer": true}
  ],
  "assert": [
    {"contains": "gpt-5.4-pro/low"},
    {"contains": "effort: medium"},
    {"line_prefix": "●"}
  ],
  "assert_mock": [
    {"contains": "Mock response from gpt-5.4-pro."}
  ]
}
