# Inherit the repo-root .envrc (GOFLAGS=-buildvcs=false for the worktree layout).
source_up

export NTFY_TOPIC="$(cat ~/.secrets/NTFY_TOPIC)"
export NTFY_API_KEY="$(cat ~/.secrets/NTFY_API_KEY)"

# Non-secret local-dev config (overrides the in-binary defaults).
# Resolve crm's event-feed address BY NAME via the mono-repo registry resolver
# (REGISTRY_ROOT = the repo root, the parent of this notify dir, which holds
# crm/etc/manifest.env and bin/registry). Upstream-named key (event-protocol.md §3).
export CRM_FEED_URL="$(REGISTRY_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)" "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/bin/registry" feed-url crm)"
export NOTIFY_FROM="tail"
export NOTIFY_NTFY_BASE_URL="https://ntfy.sh"
