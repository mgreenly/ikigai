{{define "grants_block"}}
  {{if .}}
    <ul class="list grants-list">
      {{range .}}
        <li class="row grant-row">
          <span class="name">{{.Label}}</span>
          <span class="meta" title="{{.LastUsedISO}}">{{.LastUsedRel}}</span>
          <form method="POST" action="/grants/{{.PublicID}}/revoke" class="grant-revoke">
            <button type="submit" class="btn btn-danger-ghost btn-sm">Revoke</button>
          </form>
        </li>
      {{end}}
    </ul>
  {{else}}
    <p class="empty grants-empty">No MCP clients connected yet.</p>
  {{end}}
{{end}}
