{{define "pat_block"}}
  {{if .}}
    <ul class="list pats-list">
      {{range .}}
        <li class="row pat-row">
          <span class="name">{{.Label}}</span>
          <span class="meta" title="{{.CreatedISO}}">{{.CreatedRel}}</span>
          <form method="POST" action="/pat/{{.PublicID}}/revoke" class="pat-revoke">
            <button type="submit" class="btn btn-danger-ghost btn-sm">Revoke</button>
          </form>
        </li>
      {{end}}
    </ul>
  {{else}}
    <p class="empty pats-empty">No personal access tokens yet.</p>
  {{end}}
{{end}}
