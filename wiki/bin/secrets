#!/usr/bin/env bash
# bin/secrets — seed/rotate wiki's secrets in the shared app-config blob.
#
# Workstation-side control-plane action (no ssh, no box). NON-DESTRUCTIVE
# read-modify-write of ONLY this app's key in /ikigenba/<ACCOUNT>/app-config
# (a single SecureString shared across every app on the box). Every other
# app's key in the blob is preserved untouched.
#
# wiki writes two per-box secrets into its app-config object — the two keys its
# binary fails loud without at boot (wiki/internal/wiki/config.go):
#   ANTHROPIC_API_KEY — the credential the ingest/ask agents use to call the
#       chat model (anthropic.New).
#   OPENAI_API_KEY    — the credential the embedder uses (openai.NewEmbedder)
#       for ingest/search vectors.
# Both come from ~/.secrets/<NAME> (same source as the local .envrc), each
# overridable by an env var of the same name, and NEITHER is ever printed
# (masked in the summary). Non-secret config (MODEL_ID, the search caps, the
# resource/auth URLs) is NOT stored here — the box derives it from
# IKIGENBA_DOMAIN/PORT and etc/manifest.env.
#
# Requires a live SSO session (`aws sso login --profile int`) — the user runs
# that interactively; this script does not.
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO"
. etc/manifest.env
. etc/deploy.env

PARAM="/ikigenba/${ACCOUNT}/app-config"
AWS_PROFILE_NAME="${AWS_PROFILE:-${ACCOUNT}}"
AWS_REGION_NAME="${AWS_REGION:-us-east-2}"
SECRETS_DIR="${SECRETS_DIR:-$HOME/.secrets}"

aws_() { aws --profile "$AWS_PROFILE_NAME" --region "$AWS_REGION_NAME" "$@"; }

resolve() {
  local name="$1" val
  if [ -n "${!name:-}" ]; then
    val="${!name}"
  elif [ -r "$SECRETS_DIR/$name" ]; then
    val="$(cat "$SECRETS_DIR/$name")"
  else
    echo "!! $name not set and $SECRETS_DIR/$name not readable" >&2
    exit 1
  fi
  printf '%s' "$val" | tr -d '[:space:]'
}

ANTHROPIC_KEY="$(resolve ANTHROPIC_API_KEY)"
OPENAI_KEY="$(resolve OPENAI_API_KEY)"

[ -n "$ANTHROPIC_KEY" ] || { echo "!! ANTHROPIC_API_KEY is empty" >&2; exit 1; }
[ -n "$OPENAI_KEY" ]    || { echo "!! OPENAI_API_KEY is empty" >&2; exit 1; }

# Fetch the shared blob. CRITICAL: we must NOT fall through to '{}' on any
# failure other than the parameter being genuinely absent — doing so would let
# the put-parameter --overwrite below clobber every sibling app's secret (an
# expired SSO token, AccessDenied, throttling, etc. would otherwise wipe the box).
# So classify the fetch into three cases by inspecting the captured STDERR:
#   success            -> parse stdout into BASE (or '{}' if not valid JSON)
#   ParameterNotFound  -> BASE='{}' (correct first-time seed)
#   any other failure  -> print the error and exit 1 BEFORE any write.
# We key on the ParameterNotFound error STRING, not the exit code (the AWS CLI
# returns 255 for both not-found and auth errors) and not a second describe call
# (that also fails under expired SSO, re-introducing the clobber). The fetch runs
# inside an if-condition so its non-zero exit is exempt from set -e.
FETCH_ERR="$(mktemp)"; chmod 600 "$FETCH_ERR"
trap 'rm -f "$FETCH_ERR"' EXIT
if EXISTING="$(aws_ ssm get-parameter --name "$PARAM" --with-decryption \
  --query Parameter.Value --output text 2>"$FETCH_ERR")"; then
  # case 1: success — parse, falling back to '{}' only if the value isn't JSON.
  if BASE="$(printf '%s' "$EXISTING" | jq -e . 2>/dev/null)"; then :; else BASE='{}'; fi
elif grep -q 'ParameterNotFound' "$FETCH_ERR"; then
  # case 2: parameter genuinely absent — seed a fresh blob.
  BASE='{}'
else
  # case 3: any other failure (expired/invalid SSO, AccessDenied, throttle,
  # network, ...) — refuse to write so we can't clobber the shared blob.
  echo "!! get-parameter failed (not ParameterNotFound) — refusing to write:" >&2
  cat "$FETCH_ERR" >&2
  exit 1
fi

NEW="$(printf '%s' "$BASE" | jq \
  --arg n "$APP" --arg anthropic "$ANTHROPIC_KEY" --arg openai "$OPENAI_KEY" \
  '.[$n] = {ANTHROPIC_API_KEY:$anthropic, OPENAI_API_KEY:$openai}')"

mask() { local s="$1"; [ "${#s}" -le 8 ] && { echo '****'; return; }; \
         printf '%s…%s\n' "${s:0:4}" "${s: -4}"; }
SIBLINGS="$(printf '%s' "$BASE" | jq -r --arg n "$APP" \
  'keys - [$n] | join(", ") | if . == "" then "(none)" else . end')"

echo
echo "  SECRETS — write key .${APP} into ${PARAM}"
echo "    profile/region          : ${AWS_PROFILE_NAME} / ${AWS_REGION_NAME}"
echo "    ANTHROPIC_API_KEY       : $(mask "$ANTHROPIC_KEY")"
echo "    OPENAI_API_KEY          : $(mask "$OPENAI_KEY")"
echo "    sibling keys preserved  : $SIBLINGS"
echo
printf '  Type "yes" to write: '
read -r ANS
[ "$ANS" = "yes" ] || { echo ">> aborted (nothing written)."; exit 1; }

TMP="$(mktemp)"; chmod 600 "$TMP"
trap 'rm -f "$TMP" "$FETCH_ERR"' EXIT
printf '%s' "$NEW" > "$TMP"
aws_ ssm put-parameter --name "$PARAM" \
  --type SecureString --overwrite --value "file://$TMP" >/dev/null

echo ">> .${APP} written to ${PARAM}. Apply with: bin/ship (then opsctl stage/deploy) or systemctl restart ${APP}."
