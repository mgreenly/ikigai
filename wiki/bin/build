#!/usr/bin/env bash
# bin/build — produce the deploy artifacts for the wiki service.
#
# Outputs in $REPO/build/:
#   build/wiki      — shell wrapper that becomes /opt/wiki/bin/run
#                    (metaspot-launch exec()s this). Composes the public-origin
#                    WIKI_RESOURCE_ID / WIKI_AUTH_SERVER from METASPOT_DOMAIN and
#                    execs the real binary with its listen flags.
#   build/wiki.bin  — the Go binary (linux/amd64, static, stripped),
#                    shipped to /opt/wiki/bin/wiki.bin.
#
# metaspot-launch exec()s /opt/<app>/bin/run with no args (it has already sourced
# /etc/metaspot/env and manifest.env, so METASPOT_DOMAIN and PORT are in the env).
# Non-secret public config (resource/auth URLs, data root, ingest model + cost
# ceiling) is set by the wrapper below. The ANTHROPIC_API_KEY secret is NOT set
# here — metaspot-launch injects it from SSM app-config (seeded by bin/secrets);
# its absence gracefully disables ingest (the service still serves wiki_whoami).
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO"
. etc/manifest.env

VERSION="${VERSION:-$(git describe --tags --always --dirty 2>/dev/null || echo dev)}"

mkdir -p build

# -buildvcs=false: this module is a subdirectory of the ikigai mono-repo, whose
# .git lives at the (bare) repo root. Go's automatic VCS stamping walks up to
# that root and runs git there, which fails (exit 128) and aborts the build. The
# version is injected explicitly via -ldflags below, so the VCS stamp is redundant.
CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
  go build -trimpath -buildvcs=false -ldflags "-s -w -X main.version=${VERSION}" \
    -o "build/${APP}.bin" ./cmd/wiki

cat > "build/${APP}" <<'WRAPPER'
#!/usr/bin/env bash
set -euo pipefail
: "${METASPOT_DOMAIN:?metaspot-launch must have sourced /etc/metaspot/env}"
: "${PORT:?PORT must be set (etc/manifest.env)}"
# wiki is a path-routed service mounted at /srv/wiki/ behind nginx. Its canonical
# resource id is the public mount URL, and the AS it points clients at is the
# apex front door — both built from the bare account domain.
export WIKI_RESOURCE_ID="https://${METASPOT_DOMAIN}/srv/wiki/mcp"
export WIKI_AUTH_SERVER="https://${METASPOT_DOMAIN}"
export WIKI_DB_PATH=/opt/wiki/data/wiki.db
# The filesystem content store (immutable raw/ + the curated page tree + the
# per-collection search index) lives under the app's data dir, beside the DB.
export WIKI_DATA_ROOT=/opt/wiki/data/store
# Event-plane consumer config (Task 6.1). Resolve dropbox's event-feed address BY
# NAME from the on-box registry (the resolver is this wrapper's sibling at
# /opt/wiki/bin/registry, and dropbox's manifest is a peer under /opt — the
# resolver's default REGISTRY_ROOT) — no hardcoded peer port. The feed is dropbox's
# loopback port: the event plane bypasses nginx (event-protocol.md §2), so this is a
# direct 127.0.0.1 address. DROPBOX_FEED_URL is the upstream-named key
# (event-protocol.md §3). WIKI_OWNER is NOT set here: it is an app-config secret
# (seeded by bin/secrets) already in the environment. WIKI_CONSUMER_FROM defaults to
# "tail" in the binary, so the wrapper need not set it.
export DROPBOX_FEED_URL="$("$(dirname "$0")/registry" feed-url dropbox)"
# Ingest model + per-job cost ceiling come from etc/manifest.env (already sourced
# by metaspot-launch); re-export with sane fallbacks so the wrapper is the single
# place the on-box public ingest config is composed.
export WIKI_INGEST_MODEL="${WIKI_INGEST_MODEL:-claude-sonnet-4-6}"
export WIKI_INGEST_MAX_TOKENS="${WIKI_INGEST_MAX_TOKENS:-8192}"
exec /opt/wiki/bin/wiki.bin \
  --ip 127.0.0.1 \
  --port "${PORT}"
WRAPPER
chmod 0755 "build/${APP}"

# Bundle the shared, repo-root resolver so the on-box wrapper (/opt/${APP}/bin/run)
# can resolve peer service addresses by name from their deploy manifests. bin/registry
# is the single source of truth; every service ships a byte-identical copy.
cp "$REPO/../bin/registry" "build/registry"
chmod 0755 "build/registry"

echo "build/${APP}"
echo "build/${APP}.bin"
echo "build/registry"
