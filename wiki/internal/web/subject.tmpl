{{define "subject"}}{{template "layout" .}}{{end}}

{{define "main"}}
<article aria-label="Subject page">
  <h1>{{.Subject.Title}}</h1>
  <div class="prose">{{.SubjectHTML}}</div>
</article>
{{if .Subject.Outbound}}
<nav aria-label="Mentions">
  <h2>Mentions</h2>
  <ul>
    {{range .Subject.Outbound}}<li><a href="{{.Href}}">{{.Name}}</a></li>{{end}}
  </ul>
</nav>
{{end}}
{{if .Subject.Inbound}}
<nav aria-label="Mentioned by">
  <h2>Mentioned by</h2>
  <ul>
    {{range .Subject.Inbound}}<li><a href="{{.Href}}">{{.Name}}</a></li>{{end}}
  </ul>
</nav>
{{end}}
<a href="">Ask another question</a>
{{end}}
