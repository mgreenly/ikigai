source_up
# ^ MUST be the first line: it inherits the repo-root .envrc
# (GOFLAGS=-buildvcs=false for the worktree layout). Without it this service
# .envrc shadows the root and local `go build`/`go run` dies with git exit 128
# (the worktree's bare repo lives in the parent dir).

# The ingest agent's credential. In dev, direnv injects it from ~/.secrets;
# on the box it comes from SSM app-config via ikigenba-launch. A reference only —
# the value is expanded by the shell at `direnv allow` time, never read here.
export ANTHROPIC_API_KEY="$(cat ~/.secrets/ANTHROPIC_API_KEY)"
