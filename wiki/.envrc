# Inherit the repo-root .envrc (GOFLAGS=-buildvcs=false for the worktree layout).
source_up

# AI provider keys for the four chat providers agentkit supports: Anthropic,
# OpenAI, Google (Gemini), and Z.ai (GLM). Each is referenced (not read) here;
# the `cat` runs later in your shell, so the secret value never enters an agent's
# context. The guard makes a missing key a no-op. (xAI is deliberately omitted —
# agentkit has no xAI provider.)
for k in ANTHROPIC_API_KEY OPENAI_API_KEY GEMINI_API_KEY ZAI_API_KEY; do
	if [ -f "$HOME/.secrets/$k" ]; then
		export "$k"="$(cat "$HOME/.secrets/$k")"
	fi
done
