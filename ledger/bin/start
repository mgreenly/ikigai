#!/usr/bin/env bash
# bin/start — run ledger locally on its loopback port, writing its PID to build/ledger.pid.
#
# Local-run only. The systemd-on-the-box lifecycle is owned by opsctl (deploy + the start/stop passthroughs).
# ledger binds 127.0.0.1 by default; nginx is its only real ingress.
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO"
. etc/manifest.env

BIN="build/${APP}.bin"
PIDFILE="build/${APP}.pid"

if [[ ! -x "$BIN" ]]; then
  make build
fi

if [[ -f "$PIDFILE" ]] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
  echo "ledger already running (pid $(cat "$PIDFILE"))" >&2
  exit 1
fi

LEDGER_PORT="${LEDGER_PORT:-${PORT}}" "./$BIN" serve &
echo $! > "$PIDFILE"
echo "ledger started (pid $(cat "$PIDFILE")) on 127.0.0.1:${LEDGER_PORT:-${PORT}}"
