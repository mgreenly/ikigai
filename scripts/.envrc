# Inherit the repo-root .envrc (GOFLAGS=-buildvcs=false for the worktree layout).
source_up

# scripts holds NO secret (no provider, open network). Non-secret local-dev
# config (SCRIPTS_* public config) gets added here when the service is built —
# port 3009, resource id, auth server, db path, log level, SCRIPTS_RUN_TTL, and
# the per-upstream SCRIPTS_<SRC>_FEED_URL values — composed the same way
# dashboard/notify do.
