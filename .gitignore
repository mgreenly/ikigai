# marketplace stays its own standalone repo (mgreenly/marketplace, public).
# It lives here on disk but is NOT part of the ikigai monorepo — git never
# descends into it, so its own .git and the public plugin-add URL are preserved.
/marketplace/

# --- Build artifacts ---
/*/build/
/dashboard/bin/dashboard

# --- Runtime SQLite state ---
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# --- Local environment ---
.env
.env.local
.direnv/

# --- Editor / OS ---
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# --- Local-dev stack state (bin/start): binaries, logs, pidfiles, dev SQLite ---
/tmp/

# --- wiki-eval harness output cache (P13): pure memoization, content-addressed ---
.wiki-eval-cache/

# --- build-loop ephemeral brief (gather creates, verify deletes; never committed) ---
# Every app's ralph loop writes its own project/prompts/brief.md seam.
*/project/prompts/brief.md
# The suite-level (repo-root) loop's brief.
/project/prompts/brief.md
