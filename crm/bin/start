#!/usr/bin/env bash
# bin/start — run crm locally on its loopback port, writing its PID to build/crm.pid.
#
# Local-run only. The systemd-on-the-box lifecycle is owned by opsctl (deploy + the start/stop passthroughs).
# crm binds 127.0.0.1 by default; nginx is its only real ingress.
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO"
. etc/manifest.env

BIN="build/${APP}.bin"
PIDFILE="build/${APP}.pid"

if [[ ! -x "$BIN" ]]; then
  bin/build
fi

if [[ -f "$PIDFILE" ]] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
  echo "crm already running (pid $(cat "$PIDFILE"))" >&2
  exit 1
fi

CRM_PORT="${CRM_PORT:-${PORT}}" "./$BIN" --port "${CRM_PORT:-${PORT}}" &
echo $! > "$PIDFILE"
echo "crm started (pid $(cat "$PIDFILE")) on 127.0.0.1:${CRM_PORT:-${PORT}}"
