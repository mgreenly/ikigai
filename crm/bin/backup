#!/usr/bin/env bash
# bin/backup — snapshot crm's SQLite state to
# s3://$IKIGENBA_BACKUP_BUCKET/<APP>/ under the per-app prefix convention.
#
# Layout:
#   <APP>/crm.db.<UTC>.tar.gz   one immutable DB snapshot per run
#   <APP>/latest                pointer: the newest DB snapshot's key
# Retention: keep the most recent 30 (count-based). The `latest` pointer and the
# pre-restore/ sub-prefix are never pruned here.
#
# crm is a path-routed service: it owns no TLS cert (the dashboard owns the apex
# cert), so unlike dashboard/bin/backup this is DB-only — there is no cert
# snapshot.
#
# The event-plane generation token sidecar (crm.db.generation, event-protocol.md
# §9.3) is deliberately EXCLUDED from the snapshot: a restore must mint a fresh
# epoch (bin/restore deletes the sidecar), so capturing it would defeat the
# stale-epoch protection.
#
# DB consistency: stop / copy / start.
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
. "$REPO/etc/manifest.env"
. "$REPO/etc/deploy.env"

HOST="${HOST:-${ACCOUNT}.${APEX_SUFFIX:-ikigenba.com}}"
SSH_KEY="${SSH_KEY/#\~/$HOME}"

echo ">> backup: ${SSH_USER}@${HOST}  db=/opt/${APP}/data/crm.db  -> s3://<bucket>/${APP}/"

ssh -i "$SSH_KEY" "${SSH_USER}@${HOST}" sudo APP="$APP" bash -s <<'REMOTE'
set -euo pipefail
: "${APP:?}"

ENV_FILE=/etc/ikigenba/env
DATA_DIR="/opt/${APP}/data"
DB_BASENAME=crm.db
KEEP=30

[ -r "$ENV_FILE" ] || { echo "!! $ENV_FILE missing" >&2; exit 1; }
# shellcheck disable=SC1090
. "$ENV_FILE"
: "${IKIGENBA_BACKUP_BUCKET:?}"
export AWS_DEFAULT_REGION="${IKIGENBA_AWS_REGION:-us-east-2}"
BUCKET="$IKIGENBA_BACKUP_BUCKET"
STAMP="$(date -u +%Y%m%dT%H%M%SZ)"

WORK="$(mktemp -d)"
APP_WAS_STOPPED=0
cleanup() {
  if [ "$APP_WAS_STOPPED" = 1 ]; then
    systemctl is-active --quiet "${APP}" || systemctl start "${APP}" || true
  fi
  rm -rf "$WORK"
}
trap cleanup EXIT

if [ ! -e "$DATA_DIR/$DB_BASENAME" ]; then
  echo "!! $DATA_DIR/$DB_BASENAME does not exist — nothing to back up (has ${APP} started?)" >&2
  exit 1
fi

DB_KEY="${APP}/${DB_BASENAME}.${STAMP}.tar.gz"
echo ">> stopping ${APP} for a consistent DB copy"
systemctl stop "${APP}"
APP_WAS_STOPPED=1
# Copy the SQLite fileset only (db + WAL/SHM). The generation sidecar is
# intentionally NOT copied (see header).
cp -p "$DATA_DIR/$DB_BASENAME" "$WORK/"
for ext in -wal -shm; do
  [ -e "$DATA_DIR/${DB_BASENAME}${ext}" ] && cp -p "$DATA_DIR/${DB_BASENAME}${ext}" "$WORK/"
done
echo ">> restarting ${APP}"
systemctl start "${APP}"
APP_WAS_STOPPED=0

tar -czf "$WORK/db.tar.gz" -C "$WORK" \
  $(cd "$WORK" && ls "$DB_BASENAME" "$DB_BASENAME"-* 2>/dev/null)

echo ">> uploading s3://$BUCKET/$DB_KEY"
aws s3 cp --no-progress "$WORK/db.tar.gz" "s3://$BUCKET/$DB_KEY"
printf '%s\n' "$DB_KEY" > "$WORK/db-latest"
aws s3 cp --no-progress "$WORK/db-latest" "s3://$BUCKET/${APP}/latest"

# prune <prefix> — keep newest $KEEP objects under it
mapfile -t KEYS < <(
  aws s3api list-objects-v2 --bucket "$BUCKET" --prefix "${APP}/${DB_BASENAME}." \
    --query 'sort_by(Contents,&Key)[].Key' --output text 2>/dev/null \
    | tr '\t' '\n' | sed '/^$/d' | grep -v '^None$' || true
)
COUNT="${#KEYS[@]}"
if [ "$COUNT" -gt "$KEEP" ]; then
  echo ">> pruning $((COUNT - KEEP)) old snapshot(s) (keep $KEEP)"
  for ((i = 0; i < COUNT - KEEP; i++)); do aws s3 rm "s3://$BUCKET/${KEYS[$i]}"; done
fi

echo ">> backup complete."
REMOTE
