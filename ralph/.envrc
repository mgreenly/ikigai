# Inherit the repo-root .envrc (GOFLAGS=-buildvcs=false for the worktree layout).
source_up

export ANTHROPIC_API_KEY="$(cat ~/.secrets/ANTHROPIC_API_KEY)"

# Non-secret local-dev config (RALPH_* public config) gets added here when the
# service is built — port 3004, resource id, auth server, db path, log level,
# RALPH_RUN_TTL — composed the same way dashboard/notify do above.
