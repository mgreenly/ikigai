#!/usr/bin/env bash
# bin/backup — snapshot ralph's durable state to the per-account backup bucket
# under the per-app prefix convention s3://$IKIGENBA_BACKUP_BUCKET/<APP>/.
#
# ralph's durable state (all under /opt/ralph/data/) is three things:
#   - ralph.db        the SQLite file (sessions + run history)
#   - sandboxes/      the agents' persistent work folders (the actual work product)
#   - runs/           the per-run stream-json output logs
#
# Layout in S3:
#   <APP>/data/        a mirror of /opt/ralph/data/ via `aws s3 sync` (forward-only
#                      files; sandboxes/ and runs/ sync as-is)
# The hot WAL-mode ralph.db is NOT consistent under a live sync, so we DO NOT sync
# the hot file. Instead we take a consistent DB snapshot first (SQLite
# `VACUUM INTO`, falling back to the `.backup` API) and sync THAT in place of the
# hot ralph.db, alongside the folders. ralph keeps running throughout — no stop.
#
# AWS via the box's instance role (region from /etc/ikigenba/env). The control
# leg is `aws s3 sync` run ON the box; a live SSO session is NOT required for the
# box's own credentials, but invoking this script does ssh to the box. (No deploy
# is performed in this phase — this is the authored script only.)
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO"
. etc/manifest.env
. etc/deploy.env

HOST="${HOST:-${ACCOUNT}.${APEX_SUFFIX:-ikigenba.com}}"
SSH_KEY="${SSH_KEY/#\~/$HOME}"

echo ">> backup: ${SSH_USER}@${HOST}  data=/opt/${APP}/data  -> s3://<bucket>/${APP}/data/"

ssh -i "$SSH_KEY" "${SSH_USER}@${HOST}" sudo APP="$APP" bash -s <<'REMOTE'
set -euo pipefail
: "${APP:?}"

ENV_FILE=/etc/ikigenba/env
DATA_DIR="/opt/${APP}/data"
DB_BASENAME=ralph.db

[ -r "$ENV_FILE" ] || { echo "!! $ENV_FILE missing" >&2; exit 1; }
# shellcheck disable=SC1090
. "$ENV_FILE"
: "${IKIGENBA_BACKUP_BUCKET:?}"
export AWS_DEFAULT_REGION="${IKIGENBA_AWS_REGION:-us-east-2}"
BUCKET="$IKIGENBA_BACKUP_BUCKET"
DEST="s3://$BUCKET/${APP}/data"

[ -d "$DATA_DIR" ] || { echo "!! $DATA_DIR does not exist — nothing to back up (has ${APP} started?)" >&2; exit 1; }

WORK="$(mktemp -d)"
trap 'rm -rf "$WORK"' EXIT

# ---- consistent DB snapshot (no app stop; WAL-safe) ----
SNAP=""
if [ -e "$DATA_DIR/$DB_BASENAME" ]; then
  SNAP="$WORK/$DB_BASENAME"
  echo ">> consistent DB snapshot via sqlite3 VACUUM INTO"
  if command -v sqlite3 >/dev/null 2>&1; then
    # VACUUM INTO is atomic and produces a single consistent file (no -wal/-shm).
    sqlite3 "$DATA_DIR/$DB_BASENAME" "VACUUM INTO '$SNAP'" \
      || sqlite3 "$DATA_DIR/$DB_BASENAME" ".backup '$SNAP'"
  else
    echo "!! sqlite3 not on box — cannot take a consistent snapshot" >&2
    exit 1
  fi
else
  echo ">> no $DATA_DIR/$DB_BASENAME yet — syncing folders only"
fi

# ---- sync the folders (sandboxes/ + runs/), excluding the hot DB + WAL files ----
echo ">> sync folders -> $DEST/ (excluding hot DB)"
aws s3 sync --no-progress --delete \
  --exclude "${DB_BASENAME}" \
  --exclude "${DB_BASENAME}-wal" \
  --exclude "${DB_BASENAME}-shm" \
  "$DATA_DIR/" "$DEST/"

# ---- upload the consistent DB snapshot in place of the hot file ----
if [ -n "$SNAP" ]; then
  echo ">> upload consistent snapshot -> $DEST/${DB_BASENAME}"
  aws s3 cp --no-progress "$SNAP" "$DEST/${DB_BASENAME}"
fi

echo ">> backup complete -> $DEST/"
REMOTE

echo ">> done."
