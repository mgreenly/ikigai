#!/usr/bin/env bash
# bin/restore — replace ralph's live durable state from a backups-bucket
# snapshot. Symmetric with bin/backup: an `aws s3 sync` back from
# s3://$METASPOT_BACKUP_BUCKET/<APP>/data/ into /opt/ralph/data/.
#
# Restores ALL of ralph's durable state: the consistent ralph.db snapshot, the
# sandbox folders (data/sandboxes/), and the run logs (data/runs/).
#
# Destroys live production state — always interactive, no --yes bypass. ralph is
# stopped for the swap (so no in-flight run is writing the DB/folders), the data
# dir is synced from S3, ownership/permissions are re-applied, and ralph is
# restarted. Per the lifecycle, run restore AFTER `opsctl setup ralph` and
# BEFORE the first `bin/ship ralph` → `opsctl stage`/`deploy` on a rebuilt box.
#
# AWS via the box's instance role (region from /etc/metaspot/env). Invoking this
# script does ssh to the box. (No deploy is performed in this phase — authored
# script only.)
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO"
. etc/manifest.env
. etc/deploy.env

HOST="${HOST:-${ACCOUNT}.metaspot.org}"
SSH_KEY="${SSH_KEY/#\~/$HOME}"
SSH=(ssh -i "$SSH_KEY" "${SSH_USER}@${HOST}")

# ---- Phase A: resolve the source prefix on the box (read-only) ----
RESOLVED="$("${SSH[@]}" sudo APP="$APP" bash -s <<'REMOTE'
set -euo pipefail
: "${APP:?}"
ENV_FILE=/etc/metaspot/env
[ -r "$ENV_FILE" ] || { echo "!! $ENV_FILE missing" >&2; exit 1; }
# shellcheck disable=SC1090
. "$ENV_FILE"
: "${METASPOT_BACKUP_BUCKET:?}"
export AWS_DEFAULT_REGION="${METASPOT_AWS_REGION:-us-east-2}"
B="$METASPOT_BACKUP_BUCKET"
SRC="${APP}/data"

# Confirm there is something under the prefix before we destroy anything.
COUNT="$(aws s3api list-objects-v2 --bucket "$B" --prefix "$SRC/" \
  --query 'length(Contents)' --output text 2>/dev/null || echo 0)"
[ "$COUNT" != "None" ] && [ "$COUNT" != "0" ] \
  || { echo "!! no backup objects under s3://$B/$SRC/" >&2; exit 1; }

echo "BUCKET=$B"
echo "SRC=$SRC"
echo "COUNT=$COUNT"
echo "HOSTNAME=$(hostname)"
REMOTE
)"
eval "$(printf '%s\n' "$RESOLVED" | grep -E '^(BUCKET|SRC|COUNT|HOSTNAME)=')"

# ---- Phase B: confirm on the workstation tty ----
echo
echo "  RESTORE — this overwrites live production state."
echo "    source : s3://$BUCKET/$SRC/  ($COUNT object(s))"
echo "    target : $HOSTNAME:/opt/${APP}/data/  (via $HOST)"
echo "    effect : ${APP} stopped, data/ synced from S3, ${APP} restarted."
echo "    scope  : ralph.db + sandboxes/ + runs/ all replaced."
echo
printf '  Type "yes" to proceed: '
read -r ANS
[ "$ANS" = "yes" ] || { echo ">> aborted (no changes made)."; exit 1; }

# ---- Phase C: execute the destructive restore on the box ----
"${SSH[@]}" sudo APP="$APP" SRC="$SRC" bash -s <<'REMOTE'
set -euo pipefail
: "${APP:?}" "${SRC:?}"
ENV_FILE=/etc/metaspot/env
DATA_DIR="/opt/${APP}/data"
DB_BASENAME=ralph.db

# shellcheck disable=SC1090
. "$ENV_FILE"
export AWS_DEFAULT_REGION="${METASPOT_AWS_REGION:-us-east-2}"
BUCKET="$METASPOT_BACKUP_BUCKET"

APP_WAS_STOPPED=0
cleanup() {
  if [ "$APP_WAS_STOPPED" = 1 ]; then
    systemctl is-active --quiet "${APP}" || systemctl start "${APP}" || true
  fi
}
trap cleanup EXIT

echo ">> stopping ${APP}"
systemctl stop "${APP}" || true
APP_WAS_STOPPED=1

# Remove stale WAL/SHM so the restored snapshot is the sole source of truth.
rm -f "$DATA_DIR/${DB_BASENAME}-wal" "$DATA_DIR/${DB_BASENAME}-shm"

install -d -o "$APP" -g "$APP" -m 0750 "$DATA_DIR"
echo ">> sync s3://$BUCKET/$SRC/ -> $DATA_DIR/"
aws s3 sync --no-progress --delete "s3://$BUCKET/$SRC/" "$DATA_DIR/"

chown -R "${APP}:${APP}" "$DATA_DIR"
[ -e "$DATA_DIR/$DB_BASENAME" ] && chmod 0640 "$DATA_DIR/$DB_BASENAME" || true

echo ">> starting ${APP}"
systemctl start "${APP}"
APP_WAS_STOPPED=0
sleep 2
systemctl status "${APP}" --no-pager --lines=10 || true
echo ">> restore complete: s3://$BUCKET/$SRC/ -> $DATA_DIR/"
REMOTE
