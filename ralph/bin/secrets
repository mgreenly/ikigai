#!/usr/bin/env bash
# bin/secrets — seed/rotate ralph's secrets in the shared app-config blob.
#
# Workstation-side control-plane action (no ssh, no box). NON-DESTRUCTIVE
# read-modify-write of ONLY this app's key in /metaspot/<ACCOUNT>/app-config
# (a single SecureString shared across every app on the box). Every other
# app's key in the blob is preserved untouched.
#
# ralph has exactly one secret: ANTHROPIC_API_KEY (the engine reads it via
# os.Getenv at run-time client construction). It must be seeded BEFORE first
# start — metaspot-launch hard-fails if .["ralph"] is missing from app-config.
#
# The value comes from ~/.secrets/ANTHROPIC_API_KEY (same source as the local
# .envrc); it can be overridden by an env var of the same name. The value is
# NEVER read aloud, printed, or logged — only masked in the summary below.
# Non-secret config (resource id, auth server, db path, run TTL) is NOT stored
# here — the wrapper at /opt/ralph/bin/run derives it from METASPOT_DOMAIN/PORT.
#
# Requires a live SSO session (`aws sso login --profile ai`) — the user runs
# that interactively; this script does not.
set -euo pipefail

REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO"
. etc/manifest.env
. etc/deploy.env

PARAM="/metaspot/${ACCOUNT}/app-config"
AWS_PROFILE_NAME="${AWS_PROFILE:-${ACCOUNT}}"
AWS_REGION_NAME="${AWS_REGION:-us-east-2}"
SECRETS_DIR="${SECRETS_DIR:-$HOME/.secrets}"

aws_() { aws --profile "$AWS_PROFILE_NAME" --region "$AWS_REGION_NAME" "$@"; }

resolve() {
  local name="$1" val
  if [ -n "${!name:-}" ]; then
    val="${!name}"
  elif [ -r "$SECRETS_DIR/$name" ]; then
    val="$(cat "$SECRETS_DIR/$name")"
  else
    echo "!! $name not set and $SECRETS_DIR/$name not readable" >&2
    exit 1
  fi
  printf '%s' "$val" | tr -d '[:space:]'
}

APIKEY="$(resolve ANTHROPIC_API_KEY)"

[ -n "$APIKEY" ] || { echo "!! ANTHROPIC_API_KEY is empty" >&2; exit 1; }
case "$APIKEY" in
  sk-*) ;;
  *) echo "!! ANTHROPIC_API_KEY does not look like an Anthropic API key (expected sk-…)" >&2; exit 1 ;;
esac

EXISTING="$(aws_ ssm get-parameter --name "$PARAM" --with-decryption \
  --query Parameter.Value --output text 2>/dev/null || true)"
if BASE="$(printf '%s' "$EXISTING" | jq -e . 2>/dev/null)"; then :; else BASE='{}'; fi

NEW="$(printf '%s' "$BASE" | jq \
  --arg n "$APP" --arg apikey "$APIKEY" \
  '.[$n] = {ANTHROPIC_API_KEY:$apikey}')"

mask() { local s="$1"; [ "${#s}" -le 8 ] && { echo '****'; return; }; \
         printf '%s…%s\n' "${s:0:4}" "${s: -4}"; }
SIBLINGS="$(printf '%s' "$BASE" | jq -r --arg n "$APP" \
  'keys - [$n] | join(", ") | if . == "" then "(none)" else . end')"

echo
echo "  SECRETS — write key .${APP} into ${PARAM}"
echo "    profile/region          : ${AWS_PROFILE_NAME} / ${AWS_REGION_NAME}"
echo "    ANTHROPIC_API_KEY       : $(mask "$APIKEY")"
echo "    sibling keys preserved  : $SIBLINGS"
echo
printf '  Type "yes" to write: '
read -r ANS
[ "$ANS" = "yes" ] || { echo ">> aborted (nothing written)."; exit 1; }

TMP="$(mktemp)"; chmod 600 "$TMP"
trap 'rm -f "$TMP"' EXIT
printf '%s' "$NEW" > "$TMP"
aws_ ssm put-parameter --name "$PARAM" \
  --type SecureString --overwrite --value "file://$TMP" >/dev/null

echo ">> .${APP} written to ${PARAM}. Apply with: bin/ship (then opsctl stage/deploy) or systemctl restart ${APP}."
