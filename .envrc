# .envrc — repo-root direnv config for the ikigai mono-repo.
#
# GOFLAGS=-buildvcs=false — this repo is checked out as a git *worktree* whose
# bare repo lives in the worktree's PARENT directory. Go's automatic VCS stamping
# walks up from a service module, past the worktree's `.git` file, into that bare
# repo, and runs `git status` there; a bare repo has no work tree, so it exits 128
# and aborts every plain `go build` / `go run`. Disabling VCS stamping sidesteps
# it — bin/build injects the real version via -ldflags, so the stamp is redundant.
#
# Services that keep their own .envrc (dashboard, dropbox, notify, prompts)
# `source_up` this file first so they inherit GOFLAGS; crm/ledger have no .envrc
# and pick this up directly as the nearest .envrc when walking up. Run
# `direnv allow` here and in each service dir once.
export GOFLAGS=-buildvcs=false

# ZAI_API_KEY — the prompts service's zai/glm provider reads this via getenv
# (prompts/internal/prompt/service.go maps provider "zai" -> "ZAI_API_KEY").
# prompts/.envrc also sets it for a standalone `cd prompts/`, but bin/start
# launches the whole suite from the repo root, where only this .envrc is active
# — so it must live here for a root-launched prompts to see it. Reference only,
# never a literal: the $(cat ...) runs in the user's shell at direnv-eval time.
export ZAI_API_KEY="$(cat ~/.secrets/ZAI_API_KEY)"
